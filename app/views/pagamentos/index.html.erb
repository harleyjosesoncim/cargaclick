<div class="container mx-auto p-4">
  <h1 class="text-2xl font-bold mb-4">Pagamentos</h1>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    <% @pagamentos.each do |pagamento| %>
      <div class="bg-white shadow rounded-lg p-4 flex flex-col justify-between">
        <div>
          <p class="text-sm text-gray-500">Frete: <%= pagamento.frete_id %></p>
          <p class="text-sm text-gray-500">Transportador: <%= pagamento.transportador_id %></p>
          <p class="text-lg font-semibold mt-2">R$ <%= number_to_currency(pagamento.valor, unit: "") %></p>
        </div>

        <span class="mt-3 inline-block px-2 py-1 rounded text-xs font-bold
          <%= pagamento.status == "confirmado" ? "bg-green-200 text-green-800" :
              pagamento.status == "pendente" ? "bg-yellow-200 text-yellow-800" :
              "bg-red-200 text-red-800" %>">
          <%= pagamento.status.capitalize %>
        </span>
      </div>
    <% end %>
  </div>
</div>
