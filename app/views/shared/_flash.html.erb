<!-- app/views/shared/_flash.html.erb -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4 space-y-3">
  <% flash.each do |key, message| %>
    <% next if message.blank? %>

    <% css_class, icon = case key.to_sym
      when :notice
        ["bg-green-100 border-l-4 border-green-500 text-green-700", "✅"]
      when :alert
        ["bg-red-100 border-l-4 border-red-500 text-red-700", "❌"]
      when :warning
        ["bg-yellow-100 border-l-4 border-yellow-500 text-yellow-700", "⚠️"]
      else
        ["bg-blue-100 border-l-4 border-blue-500 text-blue-700", "ℹ️"]
    end %>

    <div class="<%= css_class %> p-4 rounded-lg shadow flex items-center justify-between animate-fade-in">
      <p class="font-medium flex items-center gap-2">
        <span><%= icon %></span>
        <%= sanitize(message) %>
      </p>
      <button
        type="button"
        class="ml-4 text-sm font-bold opacity-60 hover:opacity-100 transition"
        onclick="this.parentElement.remove()">
        ✖
      </button>
    </div>
  <% end %>
</div>

