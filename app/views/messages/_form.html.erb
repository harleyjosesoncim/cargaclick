<%= form_with model: [frete, message], data: { turbo_frame: "new_message" }, class: "mt-3 flex" do |f| %>
  <%= f.text_field :content,
                   class: "flex-1 border rounded-l p-2 focus:ring-2 focus:ring-blue-500",
                   placeholder: "Digite sua mensagem..." %>
  <%= f.submit "Enviar",
               class: "bg-blue-600 text-white px-4 py-2 rounded-r hover:bg-blue-700 transition" %>
<% end %>
