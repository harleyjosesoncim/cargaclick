<%# app/views/home/index.html.erb %>
<% content_for :title, "CargaClick — Início" %>

<div class="min-h-screen flex flex-col items-center justify-center bg-gray-100 dark:bg-gray-900 px-6 py-10 transition-colors">
  <h1 class="text-4xl font-bold mb-10 text-gray-800 dark:text-gray-100 flex items-center gap-2">
    Bem-vindo ao <span class="text-blue-600 dark:text-blue-400">CargaClick</span> 🚛
  </h1>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 w-full max-w-5xl">
    <%= render "shared/card", icon: "👤", title: "Cliente",         label: "Acessar",             path: clientes_path,        color: "blue" %>
    <%= render "shared/card", icon: "🚚", title: "Transportador",   label: "Acessar",             path: transportadores_path, color: "green" %>
    <%= render "shared/card", icon: "📦", title: "Solicitar Frete", label: "Simular / Solicitar", path: new_frete_path,       color: "yellow" %>
    <%= render "shared/card", icon: "⚙️", title: "Administração",   label: "Entrar no Painel",    path: admin_root_path,      color: "red" %>
    <%= render "shared/card", icon: "⭐", title: "Fidelidade",      label: "Ver benefícios",      path: fidelidade_path,      color: "yellow" %>
    <%= render "shared/card", icon: "📊", title: "Relatórios",     label: "Consultar",           path: relatorios_path,      color: "purple" %>
    <%= render "shared/card", icon: "ℹ️", title: "Sobre",          label: "Saiba mais",          path: about_path,           color: "blue" %>
    <%= render "shared/card", icon: "📩", title: "Contato",        label: "Fale conosco",        path: contact_path,         color: "green" %>

    <%# 🔹 Card do Chat aparece só se logado e com negociação ativa %>
    <% if (cliente_signed_in? && current_cliente.fretes.where(status: "em_negociacao").exists?) ||
          (transportador_signed_in? && current_transportador.fretes.where(status: "em_negociacao").exists?) %>
      <%= render "shared/card",
            icon: "💬",
            title: "Chat",
            label: "Conversar",
            path: chats_path,
            color: "indigo" %>
    <% end %>
  </div>
</div>
