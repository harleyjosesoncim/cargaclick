<%# app/views/home/index.html.erb %>
<% content_for :title, "CargaClick — Início" %>

<div class="min-h-screen flex flex-col items-center justify-center bg-gray-100 dark:bg-gray-900 px-6 py-10 transition-colors">
  <h1 class="text-4xl font-bold mb-10 text-gray-800 dark:text-gray-100 flex items-center gap-2">
    Bem-vindo ao <span class="text-blue-600 dark:text-blue-400">CargaClick</span> 🚛
  </h1>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 w-full max-w-5xl">
    <!-- Cliente -->
    <% if cliente_signed_in? %>
      <%= render "shared/card", icon: "👤", title: "Área do Cliente",
            label: "Entrar", path: cliente_path(current_cliente), color: "blue" %>
    <% else %>
      <%= render "shared/card", icon: "👤", title: "Cliente",
            label: "Login / Cadastro", path: new_cliente_session_path, color: "blue" %>
    <% end %>

    <!-- Transportador -->
    <% if transportador_signed_in? %>
      <%= render "shared/card", icon: "🚚", title: "Área do Transportador",
            label: "Entrar", path: transportador_path(current_transportador), color: "green" %>
    <% else %>
      <%= render "shared/card", icon: "🚚", title: "Transportador",
            label: "Login / Cadastro", path: new_transportador_session_path, color: "green" %>
    <% end %>

    <!-- Solicitar Frete -->
    <%= render "shared/card", icon: "📦", title: "Solicitar Frete",
          label: "Simular / Solicitar", path: new_frete_path, color: "yellow" %>

    <!-- Administração -->
    <% if current_admin_user %>
      <%= render "shared/card", icon: "⚙️", title: "Administração",
            label: "Painel", path: admin_root_path, color: "red" %>
    <% end %>

    <!-- Fidelidade -->
    <%= render "shared/card", icon: "⭐", title: "Fidelidade",
          label: "Ver benefícios", path: fidelidade_path, color: "yellow" %>

    <!-- Relatórios -->
    <%= render "shared/card", icon: "📊", title: "Relatórios",
          label: "Consultar", path: relatorios_path, color: "purple" %>

    <!-- Sobre -->
    <%= render "shared/card", icon: "ℹ️", title: "Sobre",
          label: "Saiba mais", path: about_path, color: "blue" %>

    <!-- Contato -->
    <%= render "shared/card", icon: "📩", title: "Contato",
          label: "Fale conosco", path: contact_path, color: "green" %>

    <!-- Chat condicional -->
    <% if (cliente_signed_in? && current_cliente.fretes.em_negociacao.exists?) ||
          (transportador_signed_in? && current_transportador.fretes.em_negociacao.exists?) %>
      <%= render "shared/card", icon: "💬", title: "Chat",
            label: "Conversar", path: chats_path, color: "indigo" %>
    <% end %>
  </div>
</div>

