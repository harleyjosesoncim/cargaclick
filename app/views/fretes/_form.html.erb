<%= form_with(model: frete, local: true, class: "space-y-6") do |f| %>
  <% if frete.errors.any? %>
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg shadow">
      <h2 class="font-bold flex items-center gap-2">
        ⚠ <span><%= pluralize(frete.errors.count, "erro") %> impediram o salvamento:</span>
      </h2>
      <ul class="mt-2 list-disc list-inside text-sm">
        <% frete.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- Origem -->
  <div>
    <%= f.label :cep_origem, "Origem (CEP ou Endereço)",
                class: "block text-sm font-medium text-gray-700 dark:text-gray-200" %>
    <%= f.text_field :cep_origem,
                     placeholder: "Ex: 18000-000",
                     class: "mt-1 block w-full rounded-lg border-gray-300 shadow-sm 
                             focus:border-blue-500 focus:ring-blue-500 sm:text-sm 
                             dark:bg-gray-700 dark:border-gray-600 dark:text-white" %>
  </div>

  <!-- Destino -->
  <div>
    <%= f.label :cep_destino, "Destino (CEP ou Endereço)",
                class: "block text-sm font-medium text-gray-700 dark:text-gray-200" %>
    <%= f.text_field :cep_destino,
                     placeholder: "Ex: 11000-000",
                     class: "mt-1 block w-full rounded-lg border-gray-300 shadow-sm 
                             focus:border-blue-500 focus:ring-blue-500 sm:text-sm 
                             dark:bg-gray-700 dark:border-gray-600 dark:text-white" %>
  </div>

  <!-- Peso -->
  <div>
    <%= f.label :peso, "Peso (kg)", class: "block text-sm font-medium text-gray-700 dark:text-gray-200" %>
    <%= f.number_field :peso,
                       step: 0.01,
                       min: 0,
                       placeholder: "Ex: 120.5",
                       class: "mt-1 block w-full rounded-lg border-gray-300 shadow-sm 
                               focus:border-blue-500 focus:ring-blue-500 sm:text-sm 
                               dark:bg-gray-700 dark:border-gray-600 dark:text-white" %>
  </div>

  <!-- Volume -->
  <div>
    <%= f.label :volume, "Volume (m³)", class: "block text-sm font-medium text-gray-700 dark:text-gray-200" %>
    <%= f.number_field :volume,
                       step: 0.01,
                       min: 0,
                       placeholder: "Ex: 3.2",
                       class: "mt-1 block w-full rounded-lg border-gray-300 shadow-sm 
                               focus:border-blue-500 focus:ring-blue-500 sm:text-sm 
                               dark:bg-gray-700 dark:border-gray-600 dark:text-white" %>
  </div>

  <!-- Botão Submit -->
  <div>
    <%= f.submit (frete.persisted? ? "Atualizar Frete" : "Criar Frete"),
          class: "w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold px-4 py-2 rounded-lg shadow transition" %>
  </div>
<% end %>
