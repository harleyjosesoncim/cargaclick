<%= render "shared/navigation_buttons" %>

<h1 class="text-2xl font-bold mb-4">Novo Frete</h1>

<%= render "form", frete: @frete %>

<h2 class="text-2xl font-bold mb-6 text-gray-800 dark:text-gray-100">Novo Frete</h2>
<div class="flex space-x-4 mb-4">
  <%= link_to "⬅ Voltar para Fretes", fretes_path,
              class: "px-4 py-2 bg-gray-200 rounded-lg hover:bg-gray-300" %>

  <%= link_to "🏠 Início", root_path,
              class: "px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700" %>
</div>


<!-- Botão Voltar -->
<div class="mb-6">
  <%= link_to fretes_path,
        class: "inline-flex items-center bg-gray-200 hover:bg-gray-300 text-gray-800 font-semibold px-4 py-2 rounded-lg transition" do %>
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
    </svg>
    Voltar para Fretes
  <% end %>
</div>

<!-- Formulário Novo Frete -->
<div class="bg-white dark:bg-gray-800 shadow-md rounded-2xl p-6">
  <%= render "form", frete: @frete %>
</div>
