<nav class="bg-gradient-to-r from-blue-600 to-blue-800 shadow-lg mb-8 px-6 py-4 rounded-b-lg">
  <div class="container mx-auto flex justify-between items-center">
    <!-- Logo -->
    <%= link_to root_path, class: "text-white text-2xl font-extrabold tracking-wider hover:text-blue-200 transition duration-300" do %>
      CargaClick 🚛
    <% end %>

    <!-- Links -->
    <ul class="flex flex-wrap space-x-6 font-semibold text-lg text-white">
      <!-- Público -->
      <li><%= nav_link_to "Início", root_path %></li>
      <li><%= nav_link_to "Simular Frete", calcular_fretes_path %></li>
      <li><%= nav_link_to "Fidelidade", fidelidade_path %></li>
      <li><%= nav_link_to "Relatórios", relatorios_path %></li>
      <li><%= nav_link_to "Sobre", about_path %></li>
      <li><%= nav_link_to "Contato", contact_path %></li>

      <!-- Acesso Cliente -->
      <% if defined?(current_cliente) && current_cliente.present? %>
        <li><%= nav_link_to "Área do Cliente", cliente_path(current_cliente) %></li>
        <li><%= chat_nav_link %></li>
      <% else %>
        <li><%= nav_link_to "Login Cliente", new_cliente_session_path %></li>
      <% end %>

      <!-- Acesso Transportador -->
      <% if defined?(current_transportador) && current_transportador.present? %>
        <li><%= nav_link_to "Área do Transportador", transportador_path(current_transportador) %></li>
      <% else %>
        <li><%= nav_link_to "Login Transportador", new_transportador_session_path %></li>
      <% end %>

      <!-- Pagamentos (link global, só se a rota existir) -->
      <% if respond_to?(:pagamentos_path) %>
        <li><%= pagamentos_nav_link %></li>
      <% end %>

      <!-- Admin (apenas se logado como admin_user) -->
      <% if defined?(current_admin_user) && current_admin_user.present? %>
        <li><%= admin_nav_link %></li>
      <% end %>
    </ul>
  </div>
</nav>
