<!DOCTYPE html>
<html>
  <head>
    <title>CargaClik</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag 'application', media: 'all' %>
    <%= javascript_include_tag 'application' %>
  </head>
  <body class="bg-gray-100 text-gray-900 min-h-screen">
    <nav class="bg-blue-600 text-white p-4 shadow">
      <div class="container mx-auto flex justify-between">
        <span class="font-bold text-xl">CargaClik</span>
        <div class="space-x-4">
          <%= link_to "Clientes", clientes_path, class: "hover:underline" %>
        </div>
      </div>
    </nav>
    <% if flash[:notice] %>
      <div class="bg-green-100 text-green-800 p-2 m-4 rounded shadow"><%= flash[:notice] %></div>
    <% elsif flash[:alert] %>
      <div class="bg-red-100 text-red-800 p-2 m-4 rounded shadow"><%= flash[:alert] %></div>
    <% end %>
    <main class="container mx-auto p-4">
      <%= yield %>
    </main>
  </body>
</html>
